# Conexão Postgres (mesmo banco do Supabase). Em produção: connection string do
# Supabase (Project Settings → Database). Local de teste: postgres standalone.
DATABASE_URL=postgresql://user:pass@host:5432/postgres
# Segredo HS256 do Supabase (Project Settings → API → JWT Secret) — valida os
# tokens de admin. Deve ser o MESMO que emite os JWTs que o frontend usa.
JWT_SECRET=
# Segredo compartilhado backend↔notify para POST /events (server-to-server).
NOTIFY_INGEST_SECRET=troque-em-producao
NOTIFY_PORT=3100
NOTIFY_CORS_ORIGIN=http://localhost:5173,http://localhost:5174
